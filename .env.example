# Contact form — environment template. Copy this file to `.env.local` and fill in
# real values. `.env.local` is gitignored, so secrets are never committed.
#
#   cp .env.example .env.local   # then edit .env.local
#
# In production (Vercel), set these in the project's Environment Variables
# instead of a file.
#
# The contact route (app/api/contact/route.js) sends mail via the Resend HTTP API.

# Required — your Resend API key (https://resend.com/api-keys).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional — where inquiries are delivered (the info@ Google Group).
# Defaults to info@logixalab.com if omitted.
CONTACT_TO=info@logixalab.com

# Optional — the "From" address. Must be on a domain verified in Resend.
# It is a label only, not a real mailbox. Defaults to noreply@logixalab.com.
CONTACT_FROM=noreply@logixalab.com

# Optional — absolute site origin used for the logo image in the email body.
# Defaults to https://www.logixalab.com.
NEXT_PUBLIC_SITE_URL=https://www.logixalab.com
