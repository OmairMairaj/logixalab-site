# Contact form SMTP — copy this file to `.env.local` on the VPS and fill in real
# values. `.env.local` is gitignored, so secrets are never committed.
#
#   cp .env.example .env.local   # then edit .env.local
#
# Use your domain email's SMTP settings (e.g. from Hostinger email / Titan):
#  - Port 465  → implicit TLS (secure)
#  - Port 587  → STARTTLS

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@logixalab.com
SMTP_PASS=your-mailbox-password
# Address shown in the "From" header (usually same as SMTP_USER):
SMTP_FROM=info@logixalab.com
# Where inquiries are delivered (defaults to SMTP_USER if omitted):
CONTACT_TO=info@logixalab.com
