# Contact form email — sent via Resend (https://resend.com).
# Copy this file to `.env.local` for local dev, and set the SAME vars in
# Vercel → Project → Settings → Environment Variables for production.
# `.env.local` and all `.env*` files are gitignored, so secrets stay out of git.
#
#   cp .env.example .env.local   # then edit .env.local

# Resend API key (Resend dashboard → API Keys). Required.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where inquiries are delivered — the info@ Google Group inbox.
CONTACT_TO=info@logixalab.com

# "From" address on the email. Must be on a domain verified in Resend
# (logixalab.com). It is a label only — not a real mailbox, receives nothing.
CONTACT_FROM=noreply@logixalab.com
