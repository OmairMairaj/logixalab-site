# LogixaLab — Next.js static export on Hostinger (Apache / public_html)
# Upload the *contents* of this zip into public_html (index.html at the root).

Options -MultiViews -Indexes
RewriteEngine On
RewriteBase /

# Run PHP files (health.php, contact.php, deploy-extract.php) — never SPA-fallback them
<IfModule mod_rewrite.c>
  RewriteCond %{REQUEST_URI} \.php$ [NC]
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]
</IfModule>

# --- HTTPS (uncomment after SSL is active in hPanel) ---
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- MIME types (some shared hosts serve .js as text/html without these) ---
<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType text/css .css
  AddType font/woff2 .woff2
  AddType application/manifest+json .webmanifest
</IfModule>

# --- Security headers (when mod_headers is available) ---
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# --- Compression (when mod_deflate is available) ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# --- Cache static assets ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Serve real files and folders as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Never serve index.html for missing JS/CSS/fonts (causes broken layout)
RewriteCond %{REQUEST_URI} ^/(nxt|images)/ [NC,OR]
RewriteCond %{REQUEST_URI} \.(js|css|woff2?|png|jpe?g|webp|gif|ico|svg|webmanifest|lottie)$ [NC]
RewriteRule ^ - [R=404,L]

# Next.js export: /contact → contact.html
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# HTML pages only
RewriteRule ^ index.html [L]
